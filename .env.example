# Copy to `.env`. Values from: Supabase → Project Settings → Database.

# --- CRITICAL: password in the URL must be percent-encoded ---
# Characters like @ # : / ? & in the password break the URI. Examples:
#   password  h@ppy   →   encode as   h%40ppy
#   password  p:ass   →   encode as   p%3Aass
# Use your OS / an online "URL encode" tool on the password only, then paste into the URI.

# Primary DB URL (required for Prisma + the app). On Supabase you can use the transaction
# pooler (port 6543) here. If `prisma migrate` fails against the pooler, run migrations with
# DATABASE_URL temporarily set to the direct connection string from Supabase (port 5432).
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[ENCODED-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

JWT_SECRET="replace-with-strong-random-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Optional: admin-only signup (leave empty to disable admin signup)
# ADMIN_SIGNUP_KEY=

# Optional: transactional email (Resend — https://resend.com). Without this, emails are logged only.
# RESEND_API_KEY=re_...
# EMAIL_FROM="Digital Heroes <onboarding@resend.dev>"
